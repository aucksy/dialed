<?xml version="1.0" encoding="utf-8"?>
<!--
  KINETIK · METRONOME (Fable Collection — Twelve&Sixty design 02·E)
  Watch Face Format v2 · canvas 300×300

  Inverted pendulum keeping the beat. The ±24° swing is baked as a 24-frame
  sprite sequence (2 s ease-in-out cycle) played by the platform's
  AnimationController (ON_VISIBLE, repeating) — the only animation mechanism
  WFF offers. If a device declines to loop it, beforePlaying=FIRST_FRAME parks
  the wand at the left of its arc (the design's static fallback pose).
  AOD: wand parked vertical as a 1 px outline, dim time (~4% APL).
-->
<WatchFace width="480" height="480" clipShape="CIRCLE">
  <Metadata key="CLOCK_TYPE" value="DIGITAL" />
  <Metadata key="PREVIEW_TIME" value="10:08:32" />

  <UserConfigurations>
    <ColorConfiguration id="accent" displayName="@string/cfg_theme" defaultValue="0">
      <ColorOption id="0" displayName="@string/theme_0" colors="#FFE0704F" />
      <ColorOption id="1" displayName="@string/theme_1" colors="#FFC9A96A" />
      <ColorOption id="2" displayName="@string/theme_2" colors="#FF9FB6C9" />
    </ColorConfiguration>
    <BooleanConfiguration id="pureBlack" displayName="@string/cfg_dark" defaultValue="FALSE" />
  </UserConfigurations>

  <Scene backgroundColor="#FF000000">

    <Group name="bg_wrap" x="0" y="0" width="480" height="480">
      <Variant mode="AMBIENT" target="alpha" value="0" />
      <PartDraw name="bg" x="0" y="0" width="480" height="480">
        <Transform target="alpha" value="[CONFIGURATION.pureBlack] ? 0 : 255" />
        <Rectangle x="0" y="0" width="480" height="480">
          <Fill color="#FF0B0908" />
        </Rectangle>
      </PartDraw>
    </Group>

    <!-- Time (mono, letter-spaced) -->
    <Group name="time" x="0" y="54" width="480" height="86">
      <Variant mode="AMBIENT" target="alpha" value="0" />
      <PartText x="0" y="0" width="480" height="86">
        <Transform target="alpha" value="[IS_24_HOUR_MODE] ? 0 : 255" />
        <Text align="CENTER"><Font family="ibm_plex_mono_semibold" size="83.2" weight="SEMI_BOLD" color="#FFEDE7DA" letterSpacing="0.019">
          <Template>%s:%s<Parameter expression="[HOUR_1_12_Z]" /><Parameter expression="[MINUTE_Z]" /></Template>
        </Font></Text>
      </PartText>
      <PartText x="0" y="0" width="480" height="86">
        <Transform target="alpha" value="[IS_24_HOUR_MODE] ? 255 : 0" />
        <Text align="CENTER"><Font family="ibm_plex_mono_semibold" size="83.2" weight="SEMI_BOLD" color="#FFEDE7DA" letterSpacing="0.019">
          <Template>%s:%s<Parameter expression="[HOUR_0_23_Z]" /><Parameter expression="[MINUTE_Z]" /></Template>
        </Font></Text>
      </PartText>
    </Group>
    <Group name="time_aod" x="0" y="83" width="480" height="77" alpha="0">
      <Variant mode="AMBIENT" target="alpha" value="255" />
      <PartText x="0" y="0" width="480" height="77">
        <Transform target="alpha" value="[IS_24_HOUR_MODE] ? 0 : 255" />
        <Text align="CENTER"><Font family="ibm_plex_mono_medium" size="73.6" weight="MEDIUM" color="#80EDE7DA">
          <Template>%s:%s<Parameter expression="[HOUR_1_12_Z]" /><Parameter expression="[MINUTE_Z]" /></Template>
        </Font></Text>
      </PartText>
      <PartText x="0" y="0" width="480" height="77">
        <Transform target="alpha" value="[IS_24_HOUR_MODE] ? 255 : 0" />
        <Text align="CENTER"><Font family="ibm_plex_mono_medium" size="73.6" weight="MEDIUM" color="#80EDE7DA">
          <Template>%s:%s<Parameter expression="[HOUR_0_23_Z]" /><Parameter expression="[MINUTE_Z]" /></Template>
        </Font></Text>
      </PartText>
    </Group>

    <!-- Date · AM/PM -->
    <Group name="dateline" x="0" y="147" width="480" height="19">
      <Variant mode="AMBIENT" target="alpha" value="0" />
      <PartText x="0" y="0" width="480" height="19">
        <Transform target="alpha" value="[IS_24_HOUR_MODE] ? 0 : 255" />
        <Text align="CENTER"><Font family="ibm_plex_mono_medium" size="13.6" weight="MEDIUM" color="#FF6B6858" letterSpacing="0.35">
          <Upper><Template>%s %s · %s<Parameter expression="[DAY_OF_WEEK_S]" /><Parameter expression="[DAY_Z]" /><Parameter expression="[AMPM_STRING]" /></Template></Upper>
        </Font></Text>
      </PartText>
      <PartText x="0" y="0" width="480" height="19">
        <Transform target="alpha" value="[IS_24_HOUR_MODE] ? 255 : 0" />
        <Text align="CENTER"><Font family="ibm_plex_mono_medium" size="13.6" weight="MEDIUM" color="#FF6B6858" letterSpacing="0.35">
          <Upper><Template>%s %s<Parameter expression="[DAY_OF_WEEK_S]" /><Parameter expression="[DAY_Z]" /></Template></Upper>
        </Font></Text>
      </PartText>
    </Group>

    <!-- Dotted guide arc (chord 82,158→218,158, r=92 → centre 150,220, ±47.6°) -->
    <PartDraw name="guide" x="0" y="0" width="480" height="480">
      <Variant mode="AMBIENT" target="alpha" value="0" />
      <Arc centerX="240" centerY="352" width="294" height="294"
           startAngle="-47.6" endAngle="47.6" direction="CLOCKWISE">
        <Stroke color="#26EDE7DA" thickness="1.6" dashIntervals="2 10" cap="BUTT" />
      </Arc>
    </PartDraw>

    <!-- Pendulum wand: 24-frame swing, accent-tinted; parks on first frame if
         the platform declines to play. Hidden in AOD. -->
    <PartAnimatedImage name="wand" x="141" y="208" width="198" height="192"
                       tintColor="[CONFIGURATION.accent.0]">
      <Variant mode="AMBIENT" target="alpha" value="0" />
      <AnimationController play="ON_VISIBLE" repeat="TRUE" beforePlaying="FIRST_FRAME" />
      <SequenceImages frameRate="24">
        <Image resource="wand_00" />
        <Image resource="wand_01" />
        <Image resource="wand_02" />
        <Image resource="wand_03" />
        <Image resource="wand_04" />
        <Image resource="wand_05" />
        <Image resource="wand_06" />
        <Image resource="wand_07" />
        <Image resource="wand_08" />
        <Image resource="wand_09" />
        <Image resource="wand_10" />
        <Image resource="wand_11" />
        <Image resource="wand_12" />
        <Image resource="wand_13" />
        <Image resource="wand_14" />
        <Image resource="wand_15" />
        <Image resource="wand_16" />
        <Image resource="wand_17" />
        <Image resource="wand_18" />
        <Image resource="wand_19" />
        <Image resource="wand_20" />
        <Image resource="wand_21" />
        <Image resource="wand_22" />
        <Image resource="wand_23" />
        <Image resource="wand_24" />
        <Image resource="wand_25" />
        <Image resource="wand_26" />
        <Image resource="wand_27" />
        <Image resource="wand_28" />
        <Image resource="wand_29" />
        <Image resource="wand_30" />
        <Image resource="wand_31" />
        <Image resource="wand_32" />
        <Image resource="wand_33" />
        <Image resource="wand_34" />
        <Image resource="wand_35" />
        <Image resource="wand_36" />
        <Image resource="wand_37" />
        <Image resource="wand_38" />
        <Image resource="wand_39" />
        <Image resource="wand_40" />
        <Image resource="wand_41" />
        <Image resource="wand_42" />
        <Image resource="wand_43" />
        <Image resource="wand_44" />
        <Image resource="wand_45" />
        <Image resource="wand_46" />
        <Image resource="wand_47" />
      </SequenceImages>
    </PartAnimatedImage>

    <!-- AOD wand: parked vertical outline -->
    <PartImage name="wand_aod" x="141" y="208" width="198" height="192" alpha="0">
      <Image resource="wand_aod" />
      <Variant mode="AMBIENT" target="alpha" value="255" />
    </PartImage>

    <!-- Pivot cap (interactive fill / AOD outline) -->
    <PartDraw name="cap" x="0" y="0" width="480" height="480">
      <Variant mode="AMBIENT" target="alpha" value="0" />
      <Ellipse x="227" y="384" width="26" height="26">
        <Fill color="#FFEDE7DA" />
      </Ellipse>
    </PartDraw>
    <PartDraw name="cap_aod" x="0" y="0" width="480" height="480" alpha="0">
      <Variant mode="AMBIENT" target="alpha" value="255" />
      <Ellipse x="230" y="387" width="19" height="19">
        <Stroke color="#66EDE7DA" thickness="1.6" />
      </Ellipse>
    </PartDraw>

    <!-- Slot 1 · lower-left (accent label; default heart rate) -->
    <ComplicationSlot slotId="1" name="s1" displayName="@string/slot_1"
                      supportedTypes="SHORT_TEXT RANGED_VALUE EMPTY"
                      x="51" y="298" width="122" height="54">
      <DefaultProviderPolicy defaultSystemProvider="HEART_RATE" defaultSystemProviderType="SHORT_TEXT" />
      <BoundingBox x="0" y="0" width="122" height="54" />
      <Complication type="SHORT_TEXT">
        <PartText x="0" y="0" width="122" height="29">
          <Variant mode="AMBIENT" target="alpha" value="0" />
          <Text align="CENTER"><Font family="ibm_plex_mono_medium" size="22.4" weight="MEDIUM" color="#FFEDE7DA">
            <Template>%s<Parameter expression="[COMPLICATION.TEXT]" /></Template>
          </Font></Text>
        </PartText>
        <!-- Provider icon: swaps with every provider (Steps→Compass→Gemini), no hardcoded label. -->
        <PartImage x="49" y="27" width="24" height="24" tintColor="[CONFIGURATION.accent.0]">
          <Variant mode="AMBIENT" target="alpha" value="0" />
          <Image resource="[COMPLICATION.MONOCHROMATIC_IMAGE]" />
        </PartImage>
      </Complication>
      <Complication type="RANGED_VALUE">
        <PartText x="0" y="0" width="122" height="29">
          <Variant mode="AMBIENT" target="alpha" value="0" />
          <Text align="CENTER"><Font family="ibm_plex_mono_medium" size="22.4" weight="MEDIUM" color="#FFEDE7DA">
            <Template>%s<Parameter expression="[COMPLICATION.TEXT]" /></Template>
          </Font></Text>
        </PartText>
        <!-- Provider icon: swaps with every provider (Steps→Compass→Gemini), no hardcoded label. -->
        <PartImage x="49" y="27" width="24" height="24" tintColor="[CONFIGURATION.accent.0]">
          <Variant mode="AMBIENT" target="alpha" value="0" />
          <Image resource="[COMPLICATION.MONOCHROMATIC_IMAGE]" />
        </PartImage>
      </Complication>
      <Complication type="EMPTY" />
    </ComplicationSlot>

    <!-- Slot 2 · lower-right (default next event; the design's "alarm" has no
         system provider — assign an alarm complication to restore it) -->
    <ComplicationSlot slotId="2" name="s2" displayName="@string/slot_2"
                      supportedTypes="SHORT_TEXT RANGED_VALUE EMPTY"
                      x="307" y="298" width="122" height="54">
      <DefaultProviderPolicy defaultSystemProvider="NEXT_EVENT" defaultSystemProviderType="SHORT_TEXT" />
      <BoundingBox x="0" y="0" width="122" height="54" />
      <Complication type="SHORT_TEXT">
        <PartText x="0" y="0" width="122" height="29">
          <Variant mode="AMBIENT" target="alpha" value="0" />
          <Text align="CENTER"><Font family="ibm_plex_mono_medium" size="22.4" weight="MEDIUM" color="#FFEDE7DA">
            <Template>%s<Parameter expression="[COMPLICATION.TEXT]" /></Template>
          </Font></Text>
        </PartText>
        <!-- Provider icon: swaps with every provider (Steps→Compass→Gemini), no hardcoded label. -->
        <PartImage x="49" y="27" width="24" height="24" tintColor="#FF6B6858">
          <Variant mode="AMBIENT" target="alpha" value="0" />
          <Image resource="[COMPLICATION.MONOCHROMATIC_IMAGE]" />
        </PartImage>
      </Complication>
      <Complication type="RANGED_VALUE">
        <PartText x="0" y="0" width="122" height="29">
          <Variant mode="AMBIENT" target="alpha" value="0" />
          <Text align="CENTER"><Font family="ibm_plex_mono_medium" size="22.4" weight="MEDIUM" color="#FFEDE7DA">
            <Template>%s<Parameter expression="[COMPLICATION.TEXT]" /></Template>
          </Font></Text>
        </PartText>
        <!-- Provider icon: swaps with every provider (Steps→Compass→Gemini), no hardcoded label. -->
        <PartImage x="49" y="27" width="24" height="24" tintColor="#FF6B6858">
          <Variant mode="AMBIENT" target="alpha" value="0" />
          <Image resource="[COMPLICATION.MONOCHROMATIC_IMAGE]" />
        </PartImage>
      </Complication>
      <Complication type="EMPTY" />
    </ComplicationSlot>

    <!-- Footer -->
    <PartText name="footer" x="0" y="429" width="480" height="16">
      <Variant mode="AMBIENT" target="alpha" value="0" />
      <Text align="CENTER"><Font family="ibm_plex_mono_medium" size="11.2" weight="MEDIUM" color="#FF494638" letterSpacing="0.28">TEMPO 60 · LARGO</Font></Text>
    </PartText>

  </Scene>
</WatchFace>
