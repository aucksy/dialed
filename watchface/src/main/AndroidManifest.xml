<?xml version="1.0" encoding="utf-8"?>
<!--
  Code-free WFF manifest for the bundled Dialed default face.
  No Activity, no Service: the system finds the face via the format-version property +
  res/raw/watchface.xml. hasCode="false" (no .dex). applicationId lives in build.gradle.kts
  (com.dialed.app.watchfacepush.dialed.classic — the WFP <marketplaceAppId>.watchfacepush.<name> rule).
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-feature android:name="android.hardware.type.watch" android:required="true" />

    <application
        android:label="@string/app_name"
        android:icon="@drawable/ic_launcher"
        android:hasCode="false">

        <!-- Watch Face Format version 1 (Wear OS 4+) — widest device coverage. -->
        <property
            android:name="com.google.wear.watchface.format.version"
            android:value="1" />

        <!-- Installable without a companion phone app. -->
        <meta-data
            android:name="com.google.android.wearable.standalone"
            android:value="true" />
    </application>
</manifest>
