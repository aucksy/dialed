# Android / Gradle
*.iml
.gradle/
/local.properties
.DS_Store
build/
**/build/
captures/
.externalNativeBuild
.cxx/
*.apk
*.aab
*.ap_
*.dex

# CI-generated bundle: face APKs + validation tokens are produced fresh each build
# (tokens are matched to that build's APK bytes) — never commit them.
app/src/main/assets/faces/
app/src/main/assets/tokens/

# CI-generated bundle: the :watchface default-face APK + its validation token, staged into
# :wear assets each build (token matched to that build's APK bytes) — never commit them.
wear/src/main/assets/default_watchface.apk
wear/src/main/assets/default_watchface.token

# IDE
.idea/*
!.idea/icon.png

# Generated facepack modules are checked in (tools/gen-facepacks.mjs output) so CI needs no node step.
# Committed throwaway faces debug keystore (dialed-faces.keystore) is intentionally tracked.
# Real Play/upload keystores are provided via CI secrets and must NEVER be committed:
*-upload.keystore
*-release.keystore
*-play.jks
keystore.properties

# face-review harness per-run output (screenshots, diffs, fidelity.json) — regenerated each gate run
tools/face-review/.check/
