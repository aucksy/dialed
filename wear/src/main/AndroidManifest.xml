<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Wake the watch when a face is being pushed so the receive UI shows. -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!-- Watch Face Push: install pushed faces (required) + set one active (runtime, one-shot). -->
    <uses-permission android:name="com.google.wear.permission.PUSH_WATCH_FACES" />
    <uses-permission android:name="com.google.wear.permission.SET_PUSHED_WATCH_FACE_AS_ACTIVE" />

    <uses-feature android:name="android.hardware.type.watch" android:required="true" />

    <application
        android:name=".DialedWearApplication"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@android:style/Theme.DeviceDefault">

        <uses-library android:name="com.google.android.wearable" android:required="true" />

        <!-- Companion of the phone app: browsing/paywall live on the phone. -->
        <meta-data
            android:name="com.google.android.wearable.standalone"
            android:value="false" />

        <!-- Phase 5 will add a bundled default face + its token here:
             <meta-data android:name="com.google.android.wearable.marketplace.DEFAULT_WATCHFACE_VALIDATION_TOKEN"
                        android:value="@string/default_wf_token" />
             (paired with assets/default_watchface.apk). Omitted until that face exists. -->

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:taskAffinity="">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Receives the phone's Data-Layer push: onRequest (setup / query / uninstall) +
             onChannelOpened (APK). Every sendRequest path the phone uses MUST be declared here or
             the RPC is never delivered to onRequest (a <data> per path; OR-matched within a filter). -->
        <service
            android:name=".wfp.DialedListenerService"
            android:exported="true">
            <intent-filter>
                <action android:name="com.google.android.gms.wearable.REQUEST_RECEIVED" />
                <data android:scheme="wear" android:host="*" android:pathPrefix="/dialed/initiate_transfer" />
                <data android:scheme="wear" android:host="*" android:pathPrefix="/dialed/query_state" />
                <data android:scheme="wear" android:host="*" android:pathPrefix="/dialed/uninstall" />
            </intent-filter>
            <intent-filter>
                <action android:name="com.google.android.gms.wearable.CHANNEL_EVENT" />
                <data android:scheme="wear" android:host="*" android:pathPrefix="/dialed/transfer_apk" />
            </intent-filter>
        </service>
    </application>
</manifest>
