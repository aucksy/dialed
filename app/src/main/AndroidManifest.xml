<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Billing (Phase 2) + reaching the watch over the Data Layer (Phase 4). -->
    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:name=".DialedApplication"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Dialed.Splash">

        <!-- singleTask: the watch's "Open on phone" fires VIEW dialed://open with NEW_TASK. Without
             this, that deep link stacks a SECOND MainActivity (its own ViewModel + capability
             listener) on top of the running one; singleTask brings the existing instance forward. -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:theme="@style/Theme.Dialed.Splash">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <!-- Deep link so the Wear app's "Open on phone" (RemoteActivityHelper) can bring Dialed
                 to the foreground. The watch sends VIEW dialed://open; this filter makes MainActivity
                 resolve it. Contract mirrored in :wear (WearConstants.PHONE_DEEP_LINK). -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="dialed" android:host="open" />
            </intent-filter>
        </activity>
    </application>
</manifest>
